# Tally configuration. Copy to .env for local overrides.

# SQLAlchemy database URL. Defaults to a local SQLite file.
# On Fly.io this is set automatically by the attached Postgres cluster.
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/tally

# Demo API key accepted in the `Authorization: Bearer <key>` header.
DEMO_API_KEY=tally_sk_demo_4f9a2b7c1e8d6053

# Re-seed the database with demo data on startup when it is empty.
SEED_ON_STARTUP=true

# Drift-detection demo: flip to true to expose the v1.1 /disputes endpoints.
ENABLE_DISPUTES=false
